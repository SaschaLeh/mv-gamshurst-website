# Storyblok (Phase 3+)
STORYBLOK_DELIVERY_TOKEN=
# Lokal: draft (sieht Drafts), Production: published
STORYBLOK_VERSION=draft
# Für `npm run types:storyblok` (CLI braucht Space-ID + vorheriges `storyblok login`)
STORYBLOK_SPACE_ID=

# Cloudflare Turnstile (Phase 8, public Site-Key — wird in Build eingebettet)
PUBLIC_TURNSTILE_SITE_KEY=

# Site (für Sitemap / OG-Tags)
SITE_URL=https://mv-gamshurst.de
