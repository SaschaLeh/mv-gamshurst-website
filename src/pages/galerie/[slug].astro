---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MasonryPaginated from '../../components/gallery/MasonryPaginated.astro';
import VideoSection from '../../components/gallery/VideoSection.astro';
import Lightbox from '../../components/gallery/Lightbox.tsx';
import { imgUrl } from '../../lib/storyblok';
import { formatDate } from '../../lib/formatters';
import { breadcrumbListSchema, serializeJsonLd } from '../../lib/seo/schema';

export async function getStaticPaths() {
  const albums = await getCollection('album');
  return albums.map((album) => ({
    // full_slug ist `galerie/<slug>` → `slug`-Param hier nur der letzte Teil.
    params: { slug: album.data._meta.slug },
    props: { album: album.data },
  }));
}

type AlbumData = NonNullable<Awaited<ReturnType<typeof getStaticPaths>>[number]['props']>['album'];
const { album } = Astro.props as { album: AlbumData };
const photos = album.photos ?? [];
const videoAssets = album.videoAssets ?? [];
const videoLinks = album.videoLinks ?? [];
const dateLong = formatDate(album.date, 'long');
const dateShort = formatDate(album.date, 'short');
const albumYear = album.date && !Number.isNaN(new Date(album.date).getTime())
  ? new Date(album.date).getFullYear()
  : null;

const lightboxPhotos = photos.map((p) => ({
  full: imgUrl(p, { width: 1600, format: 'webp', quality: 88 }),
  thumb: imgUrl(p, { width: 600, format: 'webp' }),
  alt: p.alt || album.title,
}));
const masonryPhotos = photos.map((p) => ({ ...p, albumTitle: album.title }));
const lightboxId = `album-${album._meta.slug}`;

const hasCover = Boolean(album.coverImage?.filename);
const videoCount = videoAssets.length + videoLinks.filter((l) => Boolean(l?.url)).length;

const breadcrumbJsonLd = serializeJsonLd(
  breadcrumbListSchema(
    [
      { name: 'Start', path: '/' },
      { name: 'Bildergalerie', path: '/galerie' },
      { name: album.title || 'Album' },
    ],
    Astro.site!,
  ),
);
---
<Base
  title={album.title || 'Album'}
  description={`${album.title || 'Fotoalbum'} — MV Gamshurst${dateShort ? ` (${dateShort})` : ''}.`}
>
  <script slot="head" type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
  <div class="container album-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Start</a>
      <span aria-hidden="true">/</span>
      <a href="/galerie">Bildergalerie</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{album.title}</span>
    </nav>

    <header class="album-head">
      <p class="eyebrow">Album{albumYear ? ` · ${albumYear}` : ''}</p>
      <h1
        style={`view-transition-name: album-title-${album._meta.slug}; view-transition-class: album-title-vt;`}
      >{album.title || 'Album'}</h1>
      <p class="album-meta">
        {dateLong && <>{dateLong} · </>}
        {photos.length} Fotos
        {videoCount > 0 && <> · {videoCount} {videoCount === 1 ? 'Video' : 'Videos'}</>}
      </p>
    </header>

    {hasCover && (
      <div class="album-cover">
        <img
          src={imgUrl(album.coverImage, { width: 1600, height: 900, format: 'webp' })}
          srcset={`${imgUrl(album.coverImage, { width: 800, height: 450, format: 'webp' })} 800w, ${imgUrl(album.coverImage, { width: 1600, height: 900, format: 'webp' })} 1600w, ${imgUrl(album.coverImage, { width: 2400, height: 1350, format: 'webp' })} 2400w`}
          sizes="100vw"
          alt={album.coverImage.alt || album.title}
          loading="eager"
          width="1600"
          height="900"
          style={`view-transition-name: album-cover-${album._meta.slug}; view-transition-class: album-image-vt;`}
        />
      </div>
    )}

    <VideoSection
      videoAssets={videoAssets}
      videoLinks={videoLinks}
      albumCover={album.coverImage}
      albumTitle={album.title}
    />

    {photos.length > 0 ? (
      <section class="album-photos">
        <h2 class="eyebrow album-photos-head">Bilder</h2>
        <MasonryPaginated photos={masonryPhotos} lightboxId={lightboxId} />
      </section>
    ) : (
      <p class="album-empty">Dieses Album enthält noch keine Fotos.</p>
    )}
  </div>

  {photos.length > 0 && (
    <Lightbox photos={lightboxPhotos} triggerId={lightboxId} albumTitle={album.title} client:idle />
  )}
</Base>

<style>
  .album-page {
    padding-block: clamp(40px, 5vw, 72px) clamp(64px, 8vw, 96px);
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-petrol-medium); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .album-head {
    margin-bottom: clamp(24px, 3vw, 40px);
  }

  .album-head h1 { margin-top: 0.5rem; }

  .album-meta {
    color: var(--color-text-muted);
    font-size: var(--fs-body-sm);
    margin-top: 0.75rem;
  }

  .album-cover {
    margin-bottom: clamp(32px, 4vw, 56px);
    background: var(--color-card-alt-2);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .album-cover img {
    width: 100%;
    height: auto;
    max-height: 60vh;
    object-fit: cover;
  }

  /* Gleicher Abstand wie .album-videos zur jeweils darüberliegenden Section */
  .album-photos {
    margin-top: clamp(40px, 5vw, 64px);
  }

  .album-photos-head {
    margin-bottom: 1.25rem;
  }

  .album-empty {
    color: var(--color-text-muted);
    padding: 2rem;
    text-align: center;
    background: var(--color-card);
    border-radius: var(--radius-card);
  }
</style>
