---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/cards/PostCard.astro';
import { breadcrumbListSchema, serializeJsonLd } from '../../lib/seo/schema';

const allPosts = await getCollection('post');
const sorted = [...allPosts].sort((a, b) => {
  const aDate = a.data.publishedAt ? +new Date(a.data.publishedAt) : 0;
  const bDate = b.data.publishedAt ? +new Date(b.data.publishedAt) : 0;
  return bDate - aDate;
});
const [featured, ...rest] = sorted;

const breadcrumbJsonLd = serializeJsonLd(
  breadcrumbListSchema(
    [
      { name: 'Start', path: '/' },
      { name: 'Aktuelles' },
    ],
    Astro.site!,
  ),
);
---
<Base title="Aktuelles" description="Alle Beiträge, Ankündigungen und Berichte des Musikvereins Gamshurst.">
  <script slot="head" type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
  <div class="container aktuelles-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Aktuelles</span>
    </nav>

    <header class="aktuelles-page-head">
      <p class="eyebrow">Aktuelles</p>
      <h1>Neuigkeiten & Bekanntmachungen</h1>
      <p class="lead">
        Berichte, Ankündigungen und Wissenswertes rund um den Musikverein Gamshurst.
        Sortiert nach Veröffentlichungsdatum.
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="aktuelles-empty">Aktuell sind keine Beiträge veröffentlicht.</p>
    ) : (
      <>
        {featured && (
          <div class="aktuelles-featured">
            <PostCard post={featured.data} variant="featured" />
          </div>
        )}
        {rest.length > 0 && (
          <div class="aktuelles-grid">
            {rest.map((p) => <PostCard post={p.data} />)}
          </div>
        )}
      </>
    )}
  </div>
</Base>

<style>
  .aktuelles-page {
    padding-block: clamp(40px, 5vw, 72px) clamp(64px, 8vw, 96px);
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--color-petrol-medium); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .aktuelles-page-head {
    margin-bottom: clamp(32px, 5vw, 56px);
    max-width: 60ch;
  }
  .aktuelles-page-head h1 { margin-top: 0.5rem; }
  .aktuelles-page-head .lead {
    margin-top: 1rem;
    color: var(--color-text-muted);
  }

  .aktuelles-featured { margin-bottom: clamp(24px, 4vw, 40px); }

  .aktuelles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: clamp(16px, 2vw, 28px);
  }

  .aktuelles-empty {
    padding: 3rem;
    text-align: center;
    background: var(--color-card);
    border-radius: var(--radius-card);
    color: var(--color-text-muted);
  }
</style>
