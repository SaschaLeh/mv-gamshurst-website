---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { imgUrl, renderRichText } from '../../lib/storyblok';
import { formatDate } from '../../lib/formatters';
import {
  breadcrumbListSchema,
  newsArticleSchema,
  serializeJsonLd,
} from '../../lib/seo/schema';

const CATEGORY_COLORS: Record<string, string> = {
  Konzert: 'var(--color-wappen-blau)',
  Fest: 'var(--color-cat-fest)',
  Festwochenende: 'var(--color-cat-fest-alt)',
  Brassparty: 'var(--color-cat-brassparty)',
  Verein: 'var(--color-petrol-medium)',
  Sonstiges: 'var(--color-text-muted)',
};

export async function getStaticPaths() {
  const posts = await getCollection('post');
  const sorted = [...posts].sort((a, b) => {
    const aDate = a.data.publishedAt ? +new Date(a.data.publishedAt) : 0;
    const bDate = b.data.publishedAt ? +new Date(b.data.publishedAt) : 0;
    return bDate - aDate;
  });
  return sorted.map((post, idx) => ({
    params: { slug: post.data._meta.slug },
    props: {
      post: post.data,
      newer: idx > 0 ? sorted[idx - 1]!.data : null,
      older: idx < sorted.length - 1 ? sorted[idx + 1]!.data : null,
    },
  }));
}

type Props = {
  post: Awaited<ReturnType<typeof getCollection<'post'>>>[number]['data'];
  newer: Props['post'] | null;
  older: Props['post'] | null;
};

const { post, newer, older } = Astro.props as Props;
const dateLong = formatDate(post.publishedAt, 'long');
const badgeColor = CATEGORY_COLORS[post.category] ?? CATEGORY_COLORS.Sonstiges;

const bodyHtml =
  post.body && Array.isArray(post.body.content) && post.body.content.length > 0
    ? renderRichText(post.body as Parameters<typeof renderRichText>[0])
    : '';

// OG-Image: Cover via Storyblok Image-CDN auf 1200x630 (OG-Standard).
const ogImage = post.coverImage?.filename
  ? imgUrl(post.coverImage, { width: 1200, height: 630, format: 'jpeg', quality: 80, smart: true })
  : undefined;

const externalLink = post.externalLink?.url || post.externalLink?.cached_url || '';

const settings = await getEntry('siteSettings', 'site-settings');
const pageUrl = new URL(Astro.url.pathname, Astro.site!);
const articleJsonLd = serializeJsonLd(
  newsArticleSchema(post, settings?.data, pageUrl, ogImage ?? ''),
);
const breadcrumbJsonLd = serializeJsonLd(
  breadcrumbListSchema(
    [
      { name: 'Start', path: '/' },
      { name: 'Aktuelles', path: '/aktuelles' },
      { name: post.title },
    ],
    Astro.site!,
  ),
);
---
<Base title={post.title} description={post.excerpt || `${post.title} — Aktuelles vom MV Gamshurst`} ogImage={ogImage}>
  <script slot="head" type="application/ld+json" is:inline set:html={articleJsonLd} />
  <script slot="head" type="application/ld+json" is:inline set:html={breadcrumbJsonLd} />
  <article class="post">
    <div class="container post-head-wrap">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Start</a>
        <span aria-hidden="true">/</span>
        <a href="/aktuelles">Aktuelles</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{post.title}</span>
      </nav>

      <header class="post-head">
        <div class="post-meta">
          {post.category && (
            <span class="post-badge" style={`background:${badgeColor}`}>{post.category}</span>
          )}
          {dateLong && <time datetime={post.publishedAt}>{dateLong}</time>}
        </div>
        <h1 style={`view-transition-name: post-title-${post._meta.slug}; view-transition-class: post-title-vt;`}>{post.title}</h1>
        {post.excerpt && (
          <p
            class="post-lead"
            style={`view-transition-name: post-excerpt-${post._meta.slug}; view-transition-class: post-excerpt-vt;`}
          >{post.excerpt}</p>
        )}
      </header>
    </div>

    {post.coverImage?.filename && (
      <div class="post-cover">
        <img
          src={imgUrl(post.coverImage, { width: 1600, height: 900, format: 'webp' })}
          srcset={`${imgUrl(post.coverImage, { width: 800, height: 450, format: 'webp' })} 800w, ${imgUrl(post.coverImage, { width: 1600, height: 900, format: 'webp' })} 1600w, ${imgUrl(post.coverImage, { width: 2400, height: 1350, format: 'webp' })} 2400w`}
          sizes="100vw"
          alt={post.coverImage.alt || post.title}
          loading="eager"
          width="1600"
          height="900"
          style={`view-transition-name: post-cover-${post._meta.slug}; view-transition-class: post-image-vt;`}
        />
      </div>
    )}

    <div class="container post-body-wrap">
      {bodyHtml ? (
        <div class="post-body prose" set:html={bodyHtml} />
      ) : (
        <p class="post-body-empty">Für diesen Beitrag wurde noch kein Inhalt veröffentlicht.</p>
      )}

      {externalLink && (
        <a class="post-cta" href={externalLink} target="_blank" rel="noopener noreferrer">
          Mehr erfahren →
        </a>
      )}

      <nav class="post-nav" aria-label="Weitere Beiträge">
        {/* Konvention: links = älter (zurück in der Zeit), rechts = neuer (vorwärts). */}
        {older ? (
          <a class="post-nav-link post-nav--older" href={`/aktuelles/${older._meta.slug}`}>
            <span class="post-nav-direction">← Älterer Beitrag</span>
            <span class="post-nav-title">{older.title}</span>
          </a>
        ) : <span />}
        {newer ? (
          <a class="post-nav-link post-nav--newer" href={`/aktuelles/${newer._meta.slug}`}>
            <span class="post-nav-direction">Neuerer Beitrag →</span>
            <span class="post-nav-title">{newer.title}</span>
          </a>
        ) : <span />}
      </nav>
    </div>
  </article>
</Base>

<style>
  .post-head-wrap { padding-block: clamp(40px, 5vw, 72px) clamp(24px, 3vw, 40px); }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--color-petrol-medium); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .post-head { max-width: 820px; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: var(--fs-body-sm);
  }
  .post-badge {
    color: var(--color-nav-link-hover);
    padding: 0.25rem 0.7rem;
    border-radius: var(--radius-pill);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.6875rem;
  }
  .post-head h1 { margin-bottom: 0.75rem; }
  .post-lead {
    font-size: clamp(17px, 1.4vw, 20px);
    color: var(--color-text-body);
    line-height: 1.55;
  }

  .post-cover {
    margin-bottom: clamp(32px, 4vw, 56px);
    background: var(--color-card-alt-2);
  }
  .post-cover img {
    width: 100%;
    height: auto;
    max-height: 60vh;
    object-fit: cover;
  }

  .post-body-wrap {
    max-width: 820px;
    padding-bottom: clamp(48px, 7vw, 96px);
  }

  .post-body {
    color: var(--color-text-body);
    font-size: clamp(16px, 1.1vw, 18px);
    line-height: 1.75;
  }
  .post-body :global(p) + :global(p) { margin-top: 1.1rem; }
  .post-body :global(h2) {
    margin-top: 2.25rem;
    margin-bottom: 0.5rem;
    font-size: clamp(22px, 2vw, 28px);
  }
  .post-body :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.4rem;
    font-size: clamp(18px, 1.6vw, 22px);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .post-body :global(li) { margin-bottom: 0.4rem; }
  .post-body :global(img) {
    margin: 1.5rem 0;
    border-radius: var(--radius-card-sm);
    width: 100%;
    height: auto;
  }

  .post-body-empty {
    padding: 2rem;
    color: var(--color-text-muted);
    background: var(--color-card);
    border-radius: var(--radius-card);
    text-align: center;
  }

  .post-cta {
    display: inline-block;
    margin-top: 1.5rem;
    background: var(--color-primary);
    color: var(--color-nav-link-hover);
    padding: 0.85rem 1.4rem;
    border-radius: var(--radius-pill);
    font-weight: var(--fw-bold);
    font-size: var(--fs-body-sm);
    transition: transform var(--transition-fast);
  }
  .post-cta:hover { transform: translateY(-2px); }

  .post-nav {
    margin-top: clamp(48px, 6vw, 72px);
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .post-nav { grid-template-columns: 1fr; }
  }
  .post-nav-link {
    display: grid;
    gap: 0.3rem;
    padding: 1.1rem 1.3rem;
    border-radius: var(--radius-card-sm);
    background: var(--color-card);
    box-shadow: var(--shadow-card-sm);
    color: inherit;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }
  .post-nav--newer { text-align: right; }
  .post-nav-link:hover, .post-nav-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }
  .post-nav-direction {
    color: var(--color-petrol-medium);
    font-size: var(--fs-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--fw-bold);
  }
  .post-nav-title {
    color: var(--color-text-heading);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-card-title);
    line-height: 1.3;
  }
</style>
