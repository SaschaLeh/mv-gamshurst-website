---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import { renderRichText } from '../lib/storyblok';

const entry = await getEntry('impressum', 'impressum');

if (!entry && import.meta.env.STORYBLOK_DELIVERY_TOKEN) {
  throw new Error('impressum-Story fehlt. Erwarteter Slug: "impressum", Status: Published.');
}

const title = entry?.data.title || 'Impressum';
const isPlaceholder = entry?.data.isPlaceholder !== false; // default true bei fehlender Story
const bodyHtml = entry?.data.body
  ? renderRichText(entry.data.body as Parameters<typeof renderRichText>[0])
  : '';
---
<Base title={title} description="Impressum des Musikvereins Gamshurst e.V.">
  <div class="container container--reading impressum-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Start</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{title}</span>
    </nav>

    <article class="legal-card">
      {isPlaceholder && <NoticeBanner />}

      <h1>{title}</h1>

      {bodyHtml ? (
        <div class="prose legal-body" set:html={bodyHtml} />
      ) : (
        <p class="legal-empty">
          Der Impressumstext ist im CMS noch leer. Bitte vom Verein mit echten Angaben ergänzen
          (Hoster: <strong>Cloudflare, Inc.</strong>).
        </p>
      )}
    </article>
  </div>
</Base>

<style>
  .impressum-page {
    padding-block: clamp(40px, 5vw, 72px) clamp(64px, 8vw, 96px);
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--color-petrol-medium); }
  .breadcrumb a:hover { color: var(--color-primary); }

  .legal-card {
    background: var(--color-card);
    border-radius: 24px;
    padding: clamp(28px, 5vw, 56px);
    box-shadow: var(--shadow-card-sm);
  }

  .legal-card h1 {
    margin-bottom: 1.25rem;
  }

  .legal-body {
    color: var(--color-text-body);
    line-height: 1.7;
  }

  .legal-body :global(h2) {
    margin-top: 1.8rem;
    margin-bottom: 0.5rem;
    font-size: clamp(20px, 1.8vw, 26px);
  }
  .legal-body :global(h3) {
    margin-top: 1.4rem;
    margin-bottom: 0.4rem;
    font-size: clamp(18px, 1.5vw, 22px);
  }
  .legal-body :global(p) + :global(p) {
    margin-top: 1rem;
  }
  .legal-body :global(ul),
  .legal-body :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .legal-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .legal-empty {
    padding: 1.5rem;
    background: var(--color-card-alt-2);
    border-radius: var(--radius-card-sm);
    color: var(--color-text-muted);
  }
</style>
