---
import { getEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero, { type HeroBlock } from '../components/sections/Hero.astro';
import Aktuelles, { type AktuellesBlock } from '../components/sections/Aktuelles.astro';
import Termine, { type TermineBlock } from '../components/sections/Termine.astro';
import DasSindWir, { type VereinBlock } from '../components/sections/DasSindWir.astro';
import Vorstand, { type VorstandBlock } from '../components/sections/Vorstand.astro';
import GalerieTeaser, { type GalerieTeaserBlock } from '../components/sections/GalerieTeaser.astro';

const home = await getEntry('home', 'home');

if (!home && import.meta.env.STORYBLOK_DELIVERY_TOKEN) {
  throw new Error(
    'home-Story nicht gefunden. Prüfe: Slug heißt "home", Status = Published.',
  );
}

interface SectionBlock {
  component: string;
  [key: string]: unknown;
}

const sections: SectionBlock[] = (home?.data.sections ?? []) as SectionBlock[];

const KNOWN_COMPONENTS = new Set([
  'heroSection',
  'aktuellesTeaser',
  'terminePreview',
  'vereinSection',
  'vorstandSection',
  'galerieTeaser',
]);
const unknownComponents = sections
  .map((s) => s.component)
  .filter((c) => !KNOWN_COMPONENTS.has(c));
if (unknownComponents.length > 0 && import.meta.env.DEV) {
  console.warn(
    `[home] Sections nicht gerendert (Komponente unbekannt): ${unknownComponents.join(', ')}`,
  );
}
---
<Base title="MV Gamshurst" description="Musikverein Gamshurst e.V. — Aktuelles, Termine, Galerie">
  {sections.map((block) => {
    // Casts: jeder Section-Component prüft die ihm bekannten Felder selbst defensiv.
    switch (block.component) {
      case 'heroSection':
        return <Hero block={block as HeroBlock} />;
      case 'aktuellesTeaser':
        return <Aktuelles block={block as AktuellesBlock} />;
      case 'terminePreview':
        return <Termine block={block as TermineBlock} />;
      case 'vereinSection':
        return <DasSindWir block={block as VereinBlock} />;
      case 'vorstandSection':
        return <Vorstand block={block as VorstandBlock} />;
      case 'galerieTeaser':
        return <GalerieTeaser block={block as GalerieTeaserBlock} />;
      default:
        return null;
    }
  })}
</Base>
