---
import { getEntry } from 'astro:content';

const SHORT_DESCRIPTION =
  'Blasmusik aus Gamshurst seit 1925. Wir musizieren, feiern und gestalten Vereinsleben mit Leidenschaft.';
const FALLBACK_NAME = 'Musikverein Gamshurst e.V.';

const settings = await getEntry('siteSettings', 'site-settings');

// Singleton MUSS existieren wenn Storyblok angebunden ist. Stilles Fallback bei verändertem
// Slug würde leere Vereinsdaten deployen — wir wollen einen Build-Fehler.
if (!settings && import.meta.env.STORYBLOK_DELIVERY_TOKEN) {
  throw new Error(
    'siteSettings-Story nicht gefunden. Prüfe: Slug heißt "site-settings", Status = Published.',
  );
}

/**
 * Multilink-Auflösung für `linktype: 'url'` (externe Social-Links, was wir hier brauchen):
 * Storyblok füllt `url` und `cached_url` mit demselben Wert → Fallback-Reihenfolge egal.
 * Für `linktype: 'story'` (interne Story-Links, Phase 7 Richtext) müsste man auf
 * `cached_url` zurückgreifen und Slugs an URLs binden — kommt im Richtext-Resolver.
 */
const linkHref = (link?: { url?: string; cached_url?: string }): string =>
  link?.url || link?.cached_url || '';

const vereinName = settings?.data.vereinName ?? FALLBACK_NAME;
const addressLines = (settings?.data.address ?? '')
  .split('\n')
  .map((line) => line.trim())
  .filter(Boolean);
const email = settings?.data.email ?? '';
const instagramHref = linkHref(settings?.data.instagramUrl);
const facebookHref = linkHref(settings?.data.facebookUrl);
const youtubeHref = linkHref(settings?.data.youtubeUrl);

const navLinks = [
  { href: '/#aktuelles', label: 'Aktuelles' },
  { href: '/#termine', label: 'Termine' },
  { href: '/#verein', label: 'Das sind wir' },
  { href: '/#vorstand', label: 'Vorstandschaft' },
  { href: '/galerie', label: 'Bildergalerie' },
];

const year = new Date().getFullYear();
---
<footer class="site-footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="footer-watermark" aria-hidden="true">
    <img src="/assets/logo-light.svg" alt="" width="320" height="120" />
  </div>

  <div class="container footer-grid">
    <section class="footer-col">
      <img src="/assets/logo-light.svg" alt={vereinName} width="160" height="60" class="footer-logo" />
      <p>{SHORT_DESCRIPTION}</p>
    </section>

    <nav class="footer-col" aria-label="Footer Navigation">
      <h3 class="eyebrow footer-heading">Verein</h3>
      <ul>
        {navLinks.map((link) => (
          <li><a class="footer-link" href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <section class="footer-col">
      <h3 class="eyebrow footer-heading">Kontakt</h3>
      {addressLines.length > 0 && (
        <address class="footer-address">
          {addressLines.map((line) => <p>{line}</p>)}
        </address>
      )}
      {email && (
        <p>
          <a class="footer-link" href={`mailto:${email}`}>{email}</a>
        </p>
      )}
      {(instagramHref || facebookHref || youtubeHref) && (
        <ul class="footer-social" aria-label="Social Media">
          {instagramHref && (
            <li>
              <a href={instagramHref} class="footer-social-link" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                  <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.8" />
                  <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.8" />
                  <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" />
                </svg>
              </a>
            </li>
          )}
          {facebookHref && (
            <li>
              <a href={facebookHref} class="footer-social-link" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                  <path
                    d="M13.5 21v-7.5h2.6l.4-3H13.5V8.6c0-.86.27-1.45 1.52-1.45h1.62V4.43c-.28-.04-1.24-.12-2.36-.12-2.34 0-3.94 1.42-3.94 4.04V10.5H7.7v3h2.64V21h3.16z"
                    fill="currentColor"
                  />
                </svg>
              </a>
            </li>
          )}
          {youtubeHref && (
            <li>
              <a href={youtubeHref} class="footer-social-link" aria-label="YouTube" rel="noopener noreferrer" target="_blank">
                <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
                  <path
                    d="M21.6 7.2a2.5 2.5 0 0 0-1.76-1.77C18.25 5 12 5 12 5s-6.25 0-7.84.43A2.5 2.5 0 0 0 2.4 7.2C2 8.79 2 12 2 12s0 3.21.4 4.8a2.5 2.5 0 0 0 1.76 1.77C5.75 19 12 19 12 19s6.25 0 7.84-.43a2.5 2.5 0 0 0 1.76-1.77C22 15.21 22 12 22 12s0-3.21-.4-4.8zM10 15V9l5.2 3L10 15z"
                    fill="currentColor"
                  />
                </svg>
              </a>
            </li>
          )}
        </ul>
      )}
    </section>
  </div>

  <div class="container footer-bottom">
    <p class="footer-copy">&copy; {year} {vereinName}</p>
    <ul class="footer-legal">
      <li><a class="footer-link" href="/impressum">Impressum</a></li>
      <li><a class="footer-link" href="/datenschutz">Datenschutz</a></li>
      <li><a class="footer-link" href="/kontakt">Kontakt</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    margin-top: clamp(64px, 8vw, 120px);
    padding-block: clamp(48px, 5vw, 72px) clamp(24px, 3vw, 40px);
    overflow: hidden;
  }

  .footer-watermark {
    position: absolute;
    right: -40px;
    bottom: -20px;
    opacity: 0.05;
    pointer-events: none;
  }

  .footer-watermark img {
    width: clamp(220px, 28vw, 320px);
    height: auto;
  }

  .footer-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: clamp(24px, 4vw, 48px);
  }

  .footer-col {
    color: var(--color-footer-text);
  }

  .footer-col p {
    color: var(--color-footer-text);
    font-size: var(--fs-body-sm);
    line-height: 1.6;
    margin-top: 0.5rem;
  }

  .footer-logo {
    height: 60px;
    width: auto;
  }

  .footer-heading {
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .footer-link {
    color: var(--color-footer-text);
    transition: color var(--transition-fast);
    font-size: var(--fs-body-sm);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-nav-link-hover);
  }

  .footer-address {
    font-style: normal;
    margin-bottom: 0.75rem;
    font-size: var(--fs-body-sm);
  }

  .footer-address p {
    margin: 0;
    line-height: 1.5;
  }

  /* Höhere Spezifität als `.footer-col ul { display: grid }` ohne !important */
  .site-footer .footer-social {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .footer-social-link {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-footer-text);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .footer-social-link:hover,
  .footer-social-link:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-nav-link-hover);
  }

  .footer-bottom {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem 1.5rem;
    margin-top: clamp(32px, 4vw, 56px);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-copy {
    color: var(--color-footer-text);
    font-size: var(--fs-body-sm);
    opacity: 0.85;
  }

  .footer-legal {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
  }
</style>
