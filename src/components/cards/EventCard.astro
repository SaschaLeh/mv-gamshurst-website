---
import type { CollectionEntry } from 'astro:content';
import { formatDay, formatWeekdayShort, isSameDayBerlin, toDate } from '../../lib/formatters';

type EventData = CollectionEntry<'event'>['data'];

interface Props {
  event: EventData;
}

const { event } = Astro.props;
const day = formatDay(event.startDate);
const weekday = formatWeekdayShort(event.startDate);
// Mehrtägig wenn endDate gesetzt UND nicht am selben Tag in Berlin-Zeit (nicht UTC).
const isMultiDay = !!event.endDate && !isSameDayBerlin(event.startDate, event.endDate);
const endDay = isMultiDay && event.endDate ? formatDay(event.endDate) : null;
const startDateIso = toDate(event.startDate).toISOString().slice(0, 10);
---
<article class={`event-card ${event.highlight ? 'event-card--highlight' : ''}`}>
  <time class="event-day" datetime={startDateIso} aria-hidden="true">
    <span class="event-day-num">{day}{endDay && <span class="event-day-dash">–{endDay}</span>}</span>
    <span class="event-day-wd">{weekday}</span>
  </time>
  <div class="event-body">
    <h3 class="event-title">{event.title}</h3>
    <p class="event-meta">
      {event.time && <span>{event.time}</span>}
      {event.time && event.location && <span class="event-sep">·</span>}
      {event.location && <span>{event.location}</span>}
    </p>
    {event.category && <span class="event-category">{event.category}</span>}
  </div>
</article>

<style>
  .event-card {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: start;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .event-card:last-child {
    border-bottom: 0;
  }

  .event-day {
    display: grid;
    place-items: center;
    text-align: center;
    color: var(--color-text-heading);
    font-family: var(--font-display);
    line-height: 1;
  }

  .event-day-num {
    font-size: 1.85rem;
    font-weight: var(--fw-extrabold);
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .event-day-dash {
    font-size: 0.95rem;
    margin-left: 0.15em;
    font-weight: var(--fw-bold);
    color: var(--color-text-muted);
  }

  .event-day-wd {
    margin-top: 0.3rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--font-body);
    color: var(--color-text-muted);
    font-weight: var(--fw-bold);
  }

  .event-body {
    display: grid;
    gap: 0.3rem;
  }

  .event-title {
    font-size: var(--fs-card-title);
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .event-meta {
    color: var(--color-text-muted);
    font-size: var(--fs-body-sm);
  }

  .event-sep {
    margin: 0 0.4rem;
    color: var(--color-text-faint);
  }

  .event-category {
    align-self: flex-start;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-petrol-medium);
    font-weight: var(--fw-bold);
  }

  .event-card--highlight .event-day-num,
  .event-card--highlight .event-title {
    color: var(--color-gold-deepest);
  }
</style>
