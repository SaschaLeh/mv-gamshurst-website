---
import type { CollectionEntry } from 'astro:content';
import { imgUrl } from '../../lib/storyblok';

type BoardMember = CollectionEntry<'boardMember'>['data'];

interface Props {
  member: BoardMember;
}

const { member } = Astro.props;
const hasPhoto = !!member.photo?.filename;
const wordInitials = member.name
  .split(/\s+/)
  .map((s) => s.charAt(0))
  .join('')
  .slice(0, 2)
  .toUpperCase();
// Bei Ein-Wort-Namen: erste 2 Zeichen statt nur 1, damit Avatare optisch konsistent sind.
const initials = wordInitials.length >= 2 ? wordInitials : member.name.slice(0, 2).toUpperCase();
---
<article class="board-card">
  <div class="board-avatar">
    {hasPhoto && member.photo ? (
      <img
        src={imgUrl(member.photo, { width: 240, height: 240, format: 'webp', smart: true })}
        srcset={`${imgUrl(member.photo, { width: 160, height: 160, format: 'webp', smart: true })} 160w, ${imgUrl(member.photo, { width: 320, height: 320, format: 'webp', smart: true })} 320w`}
        sizes="160px"
        alt={member.photo.alt || `Porträt von ${member.name}`}
        loading="lazy"
        width="160"
        height="160"
      />
    ) : (
      <span class="board-avatar-fallback" aria-hidden="true">{initials}</span>
    )}
  </div>
  {member.role && <p class="board-role eyebrow">{member.role}</p>}
  <h3 class="board-name">{member.name}</h3>
  {member.instrument && <p class="board-instrument">{member.instrument}</p>}
</article>

<style>
  .board-card {
    text-align: center;
    padding: 1rem 0.5rem;
  }

  .board-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    margin: 0 auto 0.75rem;
    background: linear-gradient(135deg, var(--color-petrol-gradient-1), var(--color-petrol-gradient-2));
    overflow: hidden;
    display: grid;
    place-items: center;
    color: var(--color-nav-link-hover);
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: 1.5rem;
    letter-spacing: 0.03em;
  }

  .board-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .board-role {
    color: var(--color-petrol-medium);
    margin-bottom: 0.25rem;
  }

  .board-name {
    font-size: var(--fs-card-title);
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .board-instrument {
    color: var(--color-text-muted);
    font-size: var(--fs-body-sm);
    margin-top: 0.2rem;
  }
</style>
