---
import { getCollection } from 'astro:content';
import BoardMemberCard from '../cards/BoardMemberCard.astro';

export interface VorstandBlock {
  headline?: string;
}

interface Props {
  block: VorstandBlock;
}

const { block } = Astro.props;
const headline = block.headline?.trim() || 'Vorstandschaft';

const members = await getCollection('boardMember');
// sortOrder aufsteigend; bei Gleichstand Reihenfolge stabil (Index als Tiebreaker).
const sorted = [...members].sort((a, b) => (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0));
---
{sorted.length > 0 && (
  <section class="vorstand" id="vorstand">
    <div class="container">
      <header class="vorstand-head">
        <p class="eyebrow">Vorstand & Beisitzer</p>
        <h2>{headline}</h2>
      </header>
      <div class="vorstand-grid">
        {sorted.map((entry) => <BoardMemberCard member={entry.data} />)}
      </div>
    </div>
  </section>
)}

<style>
  .vorstand {
    background: var(--color-page-bg);
    padding-block: var(--section-pad-y);
  }

  .vorstand-head {
    text-align: center;
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  .vorstand-head h2 {
    margin-top: 0.5rem;
  }

  .vorstand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(186px, 1fr));
    gap: clamp(16px, 2vw, 28px);
  }
</style>
