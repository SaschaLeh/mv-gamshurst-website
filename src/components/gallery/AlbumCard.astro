---
import type { CollectionEntry } from 'astro:content';
import { imgUrl } from '../../lib/storyblok';
import { formatDate } from '../../lib/formatters';

type AlbumData = CollectionEntry<'album'>['data'];

interface Props {
  album: AlbumData;
}

const { album } = Astro.props;
const href = `/${album._meta.full_slug}`;
const photoCount = album.photos?.length ?? 0;
const date = album.date ? formatDate(album.date, 'long') : '';
---
<a class="album-card" href={href} aria-label={`${album.title} öffnen`}>
  <div class={`album-card-cover ${!album.coverImage?.filename ? 'album-card-cover--placeholder' : ''}`}>
    {album.coverImage?.filename && (
      <img
        src={imgUrl(album.coverImage, { width: 720, height: 480, format: 'webp' })}
        srcset={`${imgUrl(album.coverImage, { width: 360, height: 240, format: 'webp' })} 360w, ${imgUrl(album.coverImage, { width: 720, height: 480, format: 'webp' })} 720w, ${imgUrl(album.coverImage, { width: 1080, height: 720, format: 'webp' })} 1080w`}
        sizes="(min-width: 860px) 25vw, 90vw"
        alt={album.coverImage.alt || album.title}
        loading="lazy"
        width="720"
        height="480"
      />
    )}
    {photoCount > 0 && (
      <span class="album-card-badge" aria-label={`${photoCount} Fotos`}>
        {photoCount} Fotos
      </span>
    )}
  </div>
  <div class="album-card-meta">
    <h3 class="album-card-title">{album.title}</h3>
    {date && <p class="album-card-date">{date}</p>}
  </div>
</a>

<style>
  .album-card {
    display: block;
    background: var(--color-card);
    border-radius: var(--radius-card-lg);
    overflow: hidden;
    color: inherit;
    box-shadow: var(--shadow-card-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .album-card:hover,
  .album-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card);
  }

  .album-card-cover {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--color-card-alt-2);
  }

  .album-card-cover--placeholder {
    background: linear-gradient(135deg, var(--color-petrol-gradient-1), var(--color-petrol-gradient-2));
  }

  .album-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .album-card:hover .album-card-cover img {
    transform: scale(1.03);
  }

  .album-card-badge {
    position: absolute;
    right: 0.85rem;
    top: 0.85rem;
    background: rgba(15, 46, 54, 0.78);
    color: var(--color-nav-link-hover);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: var(--fw-bold);
    backdrop-filter: blur(6px);
  }

  .album-card-meta {
    padding: 1.1rem 1.25rem 1.35rem;
    display: grid;
    gap: 0.3rem;
  }

  .album-card-title {
    font-size: var(--fs-card-title);
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .album-card-date {
    color: var(--color-text-muted);
    font-size: var(--fs-body-sm);
  }
</style>
